GCP_PROJECT_ID=your-gcp-project
GCS_BUCKET_NAME=see-it-uploads
SHOPIFY_API_KEY=your-shopify-api-key
SHOPIFY_API_SECRET=your-shopify-api-secret
SHOPIFY_SHOP=store.myshopify.com
SHOPIFY_ALLOWED_SHOPS=store.myshopify.com,second-store.myshopify.com
SHOPIFY_HOST=seeit.example.app
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_xxx
SHOPIFY_SCOPES=read_products,read_product_listings
VERTEX_LOCATION=us-central1
VERTEX_MODEL=publishers/google/models/gemini-2.5-flash-image
SANDBOX_DAILY_LIMIT=15
# SANDBOX_ROOM_TEMPLATES accepts a JSON array string to override default templates
# SANDBOX_ROOM_TEMPLATES=[{"id":"living-room","label":"Bright living room","roomImageGcsUrl":"gs://your-bucket/living-room.jpg","placement":{"x":0.52,"y":0.62,"scale":0.42,"rotation":0}}]
POSTMARK_SERVER_TOKEN=your-postmark-token
POSTMARK_FROM_EMAIL=see-it@example.com
POSTMARK_TEMPLATE_ID=see-it-session
ALLOWED_ORIGINS=https://yourstorefront.com,https://preview.yourstorefront.com
STOREFRONT_ORIGINS=https://yourstorefront.com,https://preview.yourstorefront.com
LOG_LEVEL=info
SESSION_RETENTION_DAYS=30

